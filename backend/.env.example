# MailerSend SMTP
# Alternative: provide one full SMTP URL for Azure/Gmail/etc.
# Examples:
# SMTP_CONNECTION_STRING=smtp://username:password@smtp.office365.com:587
# SMTP_CONNECTION_STRING=smtps://username:password@smtp.office365.com:465
SMTP_CONNECTION_STRING=
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailersend_smtp_username
SMTP_PASS=your_mailersend_smtp_password
# Preferred on Render: use MailerSend HTTP API to avoid SMTP connection timeouts
MAILERSEND_API_KEY=your_mailersend_api_key
# Strongly recommended for API mode: set to a verified MailerSend sender email
MAILERSEND_FROM=no-reply@your-verified-domain.com
